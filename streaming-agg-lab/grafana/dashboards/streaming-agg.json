{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["streaming-agg-lab"],
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "utc",
  "title": "Streaming Aggregation (live)",
  "uid": "streaming-agg",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Events per 10s window, by type",
      "type": "timeseries",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-lab" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-lab" },
          "editorType": "sql",
          "queryType": "timeseries",
          "rawSql": "SELECT parseDateTimeBestEffort(window_start) AS time, sumIf(cnt, event_type='page_view') AS page_view, sumIf(cnt, event_type='add_to_cart') AS add_to_cart, sumIf(cnt, event_type='purchase') AS purchase, sumIf(cnt, event_type='search') AS search FROM lab.aggregates WHERE parseDateTimeBestEffort(window_start) >= now() - INTERVAL 30 MINUTE GROUP BY time ORDER BY time"
        }
      ]
    },
    {
      "id": 2,
      "title": "Freshness — seconds behind now (backpressure meter)",
      "type": "stat",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-lab" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-lab" },
          "editorType": "sql",
          "queryType": "table",
          "rawSql": "SELECT dateDiff('second', max(parseDateTimeBestEffort(window_start)), now()) AS staleness_seconds FROM lab.aggregates"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total events per window",
      "type": "timeseries",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-lab" },
      "gridPos": { "h": 7, "w": 18, "x": 6, "y": 9 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-lab" },
          "editorType": "sql",
          "queryType": "timeseries",
          "rawSql": "SELECT parseDateTimeBestEffort(window_start) AS time, sum(cnt) AS total_events FROM lab.aggregates WHERE parseDateTimeBestEffort(window_start) >= now() - INTERVAL 30 MINUTE GROUP BY time ORDER BY time"
        }
      ]
    }
  ]
}
